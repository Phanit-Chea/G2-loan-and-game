@{
    ViewData["Title"] = "Home Page";
}

<div class="jumbotron text-center bg-light p-5 mb-4 rounded-3">
    <h1 class="display-4 fw-bold">Welcome to Loan & Game System</h1>
    <p class="lead">A comprehensive platform for managing loans and playing classic games.</p>
    <hr class="my-4">
    <p>Sign up today to track your loans or challenge yourself with our games.</p>
    <a class="btn btn-primary btn-lg" asp-controller="Account" asp-action="Register" role="button">Get Started</a>
    <a class="btn btn-outline-secondary btn-lg ms-2" asp-controller="Account" asp-action="Login" role="button">Login</a>
</div>


