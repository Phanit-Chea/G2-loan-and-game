@model LoanSystem.Web.ViewModels.UserDashboardViewModel

@{
    ViewData["Title"] = "User Dashboard";
}

<div class="row mb-4">
    <div class="col-md-12">
        <h1>Welcome, @Model.User.FullName</h1>
        <p class="lead">Select an activity to begin.</p>
    </div>
</div>

<div class="row mb-5">
    <div class="col-md-4">
        <div class="card h-100 text-center">
            <div class="card-body">
                <h3 class="card-title">Loan Management</h3>
                <p class="card-text">Calculate amortization schedules and plan your loan.</p>
                <a asp-controller="Loan" asp-action="Index" class="btn btn-primary">Go to Loan System</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 text-center">
            <div class="card-body">
                <h3 class="card-title">Tic-Tac-Toe</h3>
                <p class="card-text">Play a classic game of Tic-Tac-Toe.</p>
                <a asp-controller="Game" asp-action="TicTacToe" class="btn btn-success">Play Tic-Tac-Toe</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 text-center">
            <div class="card-body">
                <h3 class="card-title">Car Racing</h3>
                <p class="card-text">Test your reflexes in the Car Racing game.</p>
                <a asp-controller="Game" asp-action="CarRacing" class="btn btn-danger">Play Car Racing</a>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header">
                <h3>Your Game History</h3>
            </div>
            <div class="card-body">
                @if (Model.GameHistory != null && Model.GameHistory.Any())
                {
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Game</th>
                                <th>Result</th>
                                <th>Score</th>
                                <th>Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var game in Model.GameHistory)
                            {
                                <tr>
                                    <td>@game.GameName</td>
                                    <td>@game.Result</td>
                                    <td>@game.Score</td>
                                    <td>@game.PlayedAt.ToString("g")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted">You haven't played any games yet.</p>
                }
            </div>
        </div>
    </div>
</div>

<div class="row mt-4 mb-5">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header">
                <h3>Your Loan Calculation History</h3>
            </div>
            <div class="card-body">
                @if (Model.LoanHistory != null && Model.LoanHistory.Any())
                {
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Amount</th>
                                <th>Rate</th>
                                <th>Term</th>
                                <th>Total Payment</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var loan in Model.LoanHistory)
                            {
                                <tr>
                                    <td>@loan.CreatedAt.ToString("g")</td>
                                    <td>@loan.Amount.ToString("C")</td>
                                    <td>@loan.InterestRate%</td>
                                    <td>@loan.TermYears Y @loan.TermMonths M</td>
                                    <td>@loan.TotalPayment.ToString("C")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted">No loan calculations saved yet.</p>
                }
            </div>
        </div>
    </div>
</div>
