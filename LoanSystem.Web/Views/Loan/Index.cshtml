@model LoanSystem.Web.ViewModels.LoanViewModel

@{
    ViewData["Title"] = "Amortization Calculator";
}

<div class="row">
    <!-- Left Column: Input Form -->
    <div class="col-md-5 bg-light p-4 rounded border">
        <h2 class="mb-3">Amortization Calculator</h2>
        <div asp-validation-summary="All" class="text-danger mb-3"></div>
        <form asp-action="Calculate" method="post">
            <div class="mb-3">
                <label asp-for="Amount" class="form-label"></label>
                <div class="input-group">
                    <span class="input-group-text">$</span>
                    <input asp-for="Amount" class="form-control" />
                </div>
                <span asp-validation-for="Amount" class="text-danger"></span>
            </div>
            
            <div class="row g-2 mb-3">
                <div class="col-md-8">
                     <label asp-for="TermYears" class="form-label"></label>
                    <div class="input-group">
                        <input asp-for="TermYears" class="form-control" />
                        <span class="input-group-text">years</span>
                    </div>
                </div>
                 <div class="col-md-4">
                     <label asp-for="TermMonths" class="form-label">&nbsp;</label>
                    <div class="input-group">
                        <input asp-for="TermMonths" class="form-control" />
                        <span class="input-group-text">months</span>
                    </div>
                </div>
            </div>

            <div class="mb-3">
                 <label asp-for="Rate" class="form-label"></label>
                 <div class="input-group">
                    <input asp-for="Rate" class="form-control" />
                    <span class="input-group-text">%</span>
                </div>
            </div>

            <div class="mb-3">
                 <label asp-for="StartDate" class="form-label"></label>
                 <input asp-for="StartDate" class="form-control" />
            </div>

            <div class="form-check mb-3">
                <input class="form-check-input" type="checkbox" id="extraPaymentsCheck">
                <label class="form-check-label" for="extraPaymentsCheck">
                    Optional: make extra payments
                </label>
            </div>

            <div id="extraPaymentsSection" class="p-3 mb-3 bg-white border rounded text-muted" style="display:none;">
                <div class="mb-2">
                    <label asp-for="ExtraMonthlyPayment" class="form-label small"></label>
                    <div class="input-group input-group-sm">
                        <span class="input-group-text">$</span>
                        <input asp-for="ExtraMonthlyPayment" class="form-control" />
                    </div>
                </div>
                <div class="mb-2">
                    <label asp-for="ExtraYearlyPayment" class="form-label small"></label>
                    <div class="input-group input-group-sm">
                        <span class="input-group-text">$</span>
                        <input asp-for="ExtraYearlyPayment" class="form-control" />
                    </div>
                </div>
                 <div class="mb-2">
                    <label asp-for="ExtraOneTimePayment" class="form-label small"></label>
                    <div class="row g-2">
                         <div class="col-6">
                            <div class="input-group input-group-sm">
                                <span class="input-group-text">$</span>
                                <input asp-for="ExtraOneTimePayment" class="form-control" />
                            </div>
                         </div>
                         <div class="col-6">
                             <input asp-for="ExtraOneTimePaymentDate" class="form-control form-control-sm" />
                         </div>
                    </div>
                </div>
            </div>

            <button type="submit" class="btn btn-success w-100 btn-lg">Calculate</button>
            <div class="d-flex gap-2 mt-2">
                <a asp-action="Index" class="btn btn-secondary flex-grow-1">Clear</a>
                <a asp-controller="User" asp-action="Dashboard" class="btn btn-outline-primary flex-grow-1">Back to Dashboard</a>
            </div>
        </form>
    </div>

    <!-- Right Column: Results -->
    <div class="col-md-7 ps-md-4">
        @if (Model.MonthlySchedule != null && Model.MonthlySchedule.Any())
        {
            <div class="alert alert-success d-flex justify-content-between align-items-center">
                <h3 class="m-0">Monthly Pay: @Model.MonthlyPayment.ToString("C")</h3>
                <div class="d-flex gap-2">
                     <form asp-action="Export" method="post">
                        <input type="hidden" asp-for="Amount" />
                        <input type="hidden" asp-for="Rate" />
                        <input type="hidden" asp-for="TermYears" />
                        <input type="hidden" asp-for="TermMonths" />
                        <input type="hidden" asp-for="StartDate" />
                        <button type="submit" class="btn btn-outline-success btn-sm">
                            <i class="bi bi-file-earmark-spreadsheet"></i> Export CSV
                        </button>
                    </form>
                    <i class="bi bi-calendar-check fs-2"></i>
                </div>
            </div>
            
            <p class="lead">
                With this plan, the loan will be paid off in <strong>@Model.TermYears years @(Model.TermMonths > 0 ? "and " + Model.TermMonths + " months" : "")</strong>.
            </p>

            <div class="row mb-4">
                <div class="col-md-6">
                    <canvas id="paymentChart"></canvas>
                </div>
                <div class="col-md-6">
                    <table class="table table-sm table-borderless">
                        <tr>
                            <td>Total of @Model.MonthlySchedule.Count monthly payments</td>
                            <td class="text-end">@Model.TotalPayment.ToString("C")</td>
                        </tr>
                        <tr>
                            <td>Total Interest</td>
                            <td class="text-end">@Model.TotalInterest.ToString("C")</td>
                        </tr>
                        <tr class="border-top">
                            <td>Loan Payoff Date</td>
                            <td class="text-end">@Model.PayoffDate.ToString("MMM. yyyy")</td>
                        </tr>
                    </table>
                </div>
            </div>

            <h3 class="mt-4">Amortization Schedule</h3>
             <ul class="nav nav-tabs" id="myTab" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="yearly-tab" data-bs-toggle="tab" data-bs-target="#yearly" type="button" role="tab" aria-controls="yearly" aria-selected="true">Annual Schedule</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="monthly-tab" data-bs-toggle="tab" data-bs-target="#monthly" type="button" role="tab" aria-controls="monthly" aria-selected="false">Monthly Schedule</button>
                </li>
            </ul>
            <div class="tab-content" id="myTabContent">
                <div class="tab-pane fade show active" id="yearly" role="tabpanel" aria-labelledby="yearly-tab">
                    <table class="table table-striped table-hover mt-2">
                        <thead class="table-dark">
                            <tr>
                                <th>Year</th>
                                <th>Date Range</th>
                                <th>Interest</th>
                                <th>Principal</th>
                                <th>Ending Balance</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.YearlySchedule)
                            {
                                <tr>
                                    <td>@item.Year</td>
                                    <td>@item.DateRange</td>
                                    <td>@item.Interest.ToString("C")</td>
                                    <td>@item.Principal.ToString("C")</td>
                                    <td>@item.EndingBalance.ToString("C")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="tab-pane fade" id="monthly" role="tabpanel" aria-labelledby="monthly-tab">
                     <table class="table table-sm table-striped mt-2">
                        <thead>
                            <tr>
                                <th>Month</th>
                                <th>Date</th>
                                <th>Payment</th>
                                <th>Interest</th>
                                <th>Principal</th>
                                <th>Balance</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.MonthlySchedule)
                            {
                                <tr>
                                    <td>@item.Month</td>
                                    <td>@item.Date.ToString("MMM yyyy")</td>
                                    <td>@item.Payment.ToString("C")</td>
                                    <td>@item.Interest.ToString("C")</td>
                                    <td>@item.Principal.ToString("C")</td>
                                    <td>@item.Balance.ToString("C")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const checkbox = document.getElementById('extraPaymentsCheck');
        const section = document.getElementById('extraPaymentsSection');

        checkbox.addEventListener('change', function() {
            if(this.checked) {
                section.style.display = 'block';
            } else {
                section.style.display = 'none';
            }
        });
    </script>
    @if(Model.MonthlySchedule != null && Model.MonthlySchedule.Any()) {
        <script>
            var ctx = document.getElementById('paymentChart').getContext('2d');
            var myChart = new Chart(ctx, {
                type: 'doughnut',
                data: {
                    labels: ['Principal', 'Interest'],
                    datasets: [{
                        data: [@Model.Amount, @Model.TotalInterest],
                        backgroundColor: [
                            '#36a2eb',
                            '#8bc34a'
                        ],
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: {
                            position: 'right',
                        }
                    }
                }
            });
        </script>
    }
}
