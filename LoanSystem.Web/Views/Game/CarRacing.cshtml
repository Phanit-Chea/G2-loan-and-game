@{
    ViewData["Title"] = "Car Racing";
}

<div class="row text-center mb-4">
    <div class="col-md-12">
        <h1>Car Racing</h1>
        <p>Use Left/Right Arrows to Move. Avoid Red Blocks!</p>
        <h3 id="score">Score: 0</h3>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-md-auto">
        <canvas id="gameCanvas" width="400" height="600" style="border:1px solid #000000; background-color: #333;"></canvas>
        <div class="mt-3">
             <button id="startBtn" class="btn btn-success w-100">Start Game</button>
             <a asp-controller="User" asp-action="Dashboard" class="btn btn-secondary w-100 mt-2">Back to Dashboard</a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const canvas = document.getElementById("gameCanvas");
        const ctx = canvas.getContext("2d");
        const scoreElement = document.getElementById("score");
        const startBtn = document.getElementById("startBtn");

        // Game State
        // Hitbox sizes (smaller than visual for forgiving gameplay)
        let carWidth = 30;
        let carHeight = 50;
        let carX = canvas.width / 2 - carWidth / 2;
        let carY = canvas.height - carHeight - 20;
        
        let obstacles = []; // Enemies
        let coins = [];     // Coins
        
        let score = 0;
        let gameRunning = false;
        let speed = 5;
        let animationId;

        // Assets
        const playerSprite = "🏎️";
        const enemySprite = "🚙";
        const coinSprite = "💰";
        const fontSize = 40; // Smaller visual size

        document.addEventListener("keydown", moveCar);
        startBtn.addEventListener("click", startGame);

        function startGame() {
            if(gameRunning) return;
            resetGame();
            gameRunning = true;
            loop();
        }

        function resetGame() {
            carX = canvas.width / 2 - carWidth / 2;
            obstacles = [];
            coins = [];
            score = 0;
            speed = 5;
            scoreElement.textContent = "Score: " + score;
        }

        function moveCar(e) {
            if(!gameRunning) return;
            if (e.key === "ArrowLeft" && carX > 0) {
                carX -= 20;
            } else if (e.key === "ArrowRight" && carX < canvas.width - carWidth) {
                carX += 20;
            }
        }

        function spawnObjects() {
            // Spawn Enemy
            if(Math.random() < 0.02) {
                let width = 30; // Hitbox width
                let x = Math.random() * (canvas.width - width);
                obstacles.push({x: x, y: -100, width: width, height: 50});
            }
            
            // Spawn Coin
            if(Math.random() < 0.03) {
                let width = 30;
                let x = Math.random() * (canvas.width - width);
                coins.push({x: x, y: -100, width: width, height: 30});
            }
        }

        function updateGameObjects() {
            // Update Enemies
            for(let i = 0; i < obstacles.length; i++) {
                obstacles[i].y += speed;

                // Collision with Player (Game Over)
                if (rectIntersect(carX, carY, carWidth, carHeight, obstacles[i].x, obstacles[i].y, obstacles[i].width, obstacles[i].height)) {
                    gameOver();
                    return;
                }

                // Remove off-screen
                if(obstacles[i].y > canvas.height) {
                    obstacles.splice(i, 1);
                    i--;
                }
            }

            // Update Coins
            for(let i = 0; i < coins.length; i++) {
                coins[i].y += speed;

                // Collision with Player (Collect Coin)
                if (rectIntersect(carX, carY, carWidth, carHeight, coins[i].x, coins[i].y, coins[i].width, coins[i].height)) {
                    score += 50; // Points for coin
                    scoreElement.textContent = "Score: " + score;
                    coins.splice(i, 1);
                    i--;
                    continue; // Skip rest of loop for this coin
                }

                // Remove off-screen
                if(coins[i].y > canvas.height) {
                    coins.splice(i, 1);
                    i--;
                }
            }
        }
        
        function rectIntersect(x1, y1, w1, h1, x2, y2, w2, h2) {
            return x2 < x1 + w1 && x2 + w2 > x1 && y2 < y1 + h1 && y2 + h2 > y1;
        }

        function draw() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            
            // Draw Road
            ctx.fillStyle = "#333";
            ctx.fillRect(0, 0, canvas.width, canvas.height);
            
            ctx.strokeStyle = "white";
            ctx.setLineDash([20, 20]);
            ctx.beginPath();
            ctx.moveTo(canvas.width / 2, 0);
            ctx.lineTo(canvas.width / 2, canvas.height);
            ctx.stroke();

            ctx.font = fontSize + "px Arial";
            ctx.textBaseline = "top"; // Easier alignment

            // Draw Player
            // Emoji draws slightly larger than hitbox to look nice (hitbox is "core")
            ctx.fillText(playerSprite, carX - 5, carY - 5); 

            // Draw Enemies
            for(let obs of obstacles) {
                ctx.fillText(enemySprite, obs.x - 5, obs.y - 5);
                // Debug Hitbox (Uncomment to see green box around danger zone)
                // ctx.strokeStyle = "green"; ctx.strokeRect(obs.x, obs.y, obs.width, obs.height);
            }

            // Draw Coins
            for(let coin of coins) {
                ctx.fillText(coinSprite, coin.x - 2, coin.y - 2);
            }
        }

        function loop() {
            if(!gameRunning) return;

            spawnObjects();
            updateGameObjects();
            if(gameRunning) draw(); // Only draw if still running (prevent overwrite of Game Over screen)

            animationId = requestAnimationFrame(loop);
        }

        function gameOver() {
            gameRunning = false;
            cancelAnimationFrame(animationId);
            
            // Draw Game Over Screen
            ctx.fillStyle = "rgba(0, 0, 0, 0.7)";
            ctx.fillRect(0, 0, canvas.width, canvas.height);
            
            ctx.fillStyle = "white";
            ctx.font = "bold 50px Arial";
            ctx.fillText("Game Over", 60, canvas.height / 2);
            
            ctx.font = "30px Arial";
            ctx.fillText("Final Score: " + score, 100, canvas.height / 2 + 50);

            saveScore(score, "Score: " + score);
        }

        function saveScore(score, result) {
            fetch('/Game/SaveScore', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    gameName: "CarRacing",
                    score: score,
                    result: result
                })
            }).then(res => {
                 if(res.ok) console.log("Score saved");
            });
        }
    </script>
}
